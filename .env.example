# ─── VerdictAI Environment Configuration ───────────────────────────────────
#
# Copy this file to .env and fill in your values. The .env file is loaded
# automatically on application startup (via python-dotenv).
#
# LLM configuration:
# OpenRouter unifies every major provider behind an OpenAI-compatible API.
# Sign up at https://openrouter.ai/ to get a key.

# OpenRouter API key (required for LLM features)
OPENROUTER_API_KEY=

# LLM model identifier (OpenRouter model ID)
# Recommended balanced options:
#   anthropic/claude-3.5-haiku       — Best reasoning/cost for legal text
#   openai/gpt-4o-mini                — Industry standard, very cheap
#   google/gemini-2.0-flash-001      — Fast, solid structured output
#   anthropic/claude-3.5-sonnet      — Best quality, more expensive
LLM_MODEL=anthropic/claude-3.5-haiku

# Timeout for LLM calls in seconds
LLM_TIMEOUT=60

# Max tokens per LLM response
LLM_MAX_TOKENS=4096

# LLM temperature (0.0 = deterministic, 1.0 = creative)
# Keep low for structured JSON extraction
LLM_TEMPERATURE=0.1

# ─── Application Configuration ────────────────────────────────────────────

# Database path (relative to project root)
DB_PATH=verdict_ai.db

# Confidence thresholds (leave defaults unless you know what you're doing)
CONF_AUTO_COMMIT=0.85
CONF_MANDATORY_FLOOR=0.50
CONF_CONSERVATIVE_AUTO=0.90
CONF_CONSERVATIVE_FLOOR=0.60

# Entity match threshold
ENTITY_MATCH_THRESHOLD=0.85

# CPM calibration threshold (number of entries before conservative thresholds lift)
CPM_CALIBRATION_THRESHOLD=50
